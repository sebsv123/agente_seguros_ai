# ====== PostgreSQL/pgvector (Linux) ======
POSTGRES_USER=agente
POSTGRES_PASSWORD=cambia_esto_por_tu_password_segura
POSTGRES_DB=agente_ai
PG_PORT=5432

# ====== Backend ======
BACKEND_PORT=8000
DB_DSN=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ====== Ingest desde Windows ======
# Misma contraseña que POSTGRES_PASSWORD, pero con la IP del Linux
INGEST_PW=${POSTGRES_PASSWORD}
LINUX_IP=192.168.1.Y
INGEST_DB_DSN=postgresql://agente_ingest:${INGEST_PW}@${LINUX_IP}:5432/agente_ai

# ====== LLM (DeepSeek → Groq → OpenAI fallback) ======
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ====== Meta / WhatsApp ======
META_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=
META_APP_SECRET=
META_SIGNATURE_MODE=dev
META_WA_TOKEN=
WA_TOKEN=
WA_PHONE_NUMBER_ID=
DEFAULT_WA_PHONE_E164=34603448765

# ====== RAG / KB ======
KB_SCORE_THRESHOLD=0.55
KB_TOP_K=5
KB_ADMIN_TOKEN=
KB_DATA_DIR=./data

# ====== Auto WA / Scoring ======
AUTO_WA_ENABLED=1
AUTO_WA_SCORE_THRESHOLD=6

# ====== n8n ======
N8N_WEBHOOK_URL=
N8N_TIMEOUT=8

# ====== Google Calendar (opcional) ======
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# ====== Whisper (transcripción audio) ======
WHISPER_MODEL=whisper-1

# ====== Notifier (alertas equipo) ======
TEAM_WHATSAPP_NUMBER=34603448765
ALERT_SCORE_THRESHOLD=8

# ====== Admin ======
DASHBOARD_URL=http://localhost:8000/dashboard

# ====== Entorno ======
# development / production
# En Oracle SIEMPRE poner production
APP_ENV=development

# ── OCI Object Storage (para KB en Oracle Cloud) ──────────────
# Namespace: ver en OCI Console → Object Storage → Namespace
OCI_NAMESPACE=
# Nombre del bucket (crear en OCI Console)
OCI_BUCKET_NAME=agente-rosa-kb
# Región donde está el bucket
OCI_REGION=eu-madrid-1
# En Oracle VM: usar Instance Principal (1), en local: usar config file (0)
OCI_USE_INSTANCE_PRINCIPAL=1
# Solo necesario en local (desarrollo):
OCI_CONFIG_FILE=~/.oci/config
OCI_CONFIG_PROFILE=DEFAULT

# ── n8n ───────────────────────────────────────────────
N8N_HOST=n8n.valentinproteccionintegral.com
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

# ── servidor_vpi ──────────────────────────────────────
# (el .env del servidor_vpi se gestiona en su propio repo)
