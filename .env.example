# ====== PostgreSQL/pgvector (Linux) ======
POSTGRES_USER=agente
POSTGRES_PASSWORD=cambia_esto_por_tu_password_segura
POSTGRES_DB=agente_ai
PG_PORT=5432

# ====== Backend ======
BACKEND_PORT=8000
DB_DSN=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ====== Ingest desde Windows ======
# Misma contraseña que POSTGRES_PASSWORD, pero con la IP del Linux
INGEST_PW=${POSTGRES_PASSWORD}
LINUX_IP=192.168.1.Y
INGEST_DB_DSN=postgresql://agente_ingest:${INGEST_PW}@${LINUX_IP}:5432/agente_ai

# ====== API externa (DeepSeek o Groq) ======
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
DEEPSEEK_API_KEY=

# ====== Meta / WhatsApp ======
META_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=
META_APP_SECRET=
DEFAULT_WA_PHONE_E164=34603448765
WA_PHONE_NUMBER_ID=
META_WA_TOKEN=

# ====== Admin ======
KB_ADMIN_TOKEN=
DASHBOARD_URL=http://localhost:8000/dashboard
