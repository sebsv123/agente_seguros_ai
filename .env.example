# ══════════════════════════════════════════════════════
# Agente Rosa — Variables de Entorno
# Copia este archivo a .env y rellena los valores
# ══════════════════════════════════════════════════════

# ─── Base de datos (PostgreSQL + pgvector) ───────────
POSTGRES_PASSWORD=agente_pw
DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}

# ─── n8n ─────────────────────────────────────────────
N8N_ENCRYPTION_KEY=CHANGE_ME_run_openssl_rand_hex_32

# ─── Cloudflare Tunnel ───────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=

# ─── Meta / Instagram ────────────────────────────────
META_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=
META_APP_SECRET=
META_SIGNATURE_MODE=dev

# ─── WhatsApp ────────────────────────────────────────
DEFAULT_WA_PHONE_E164=34603448765
WA_TOKEN=

# ─── LLM (OpenAI — opcional) ─────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── LLM (Groq — alternativa) ────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─── n8n Webhook ─────────────────────────────────────
N8N_WEBHOOK_URL=
N8N_TIMEOUT=8

# ─── Backend DB ──────────────────────────────────────
DB_DSN=postgresql://agente:${POSTGRES_PASSWORD}@localhost:5433/agente

# ─── KB / RAG ────────────────────────────────────────
KB_SCORE_THRESHOLD=0.55
KB_TOP_K=5
KB_ADMIN_TOKEN=
KB_DATA_DIR=./data

# ─── Auto WhatsApp ───────────────────────────────────
AUTO_WA_ENABLED=1
AUTO_WA_SCORE_THRESHOLD=0.7

# ====== WhatsApp Cloud API ======
WA_PHONE_NUMBER_ID=  # ID del número de teléfono en Meta Business
META_WA_TOKEN=       # Token de acceso de WhatsApp Cloud API
