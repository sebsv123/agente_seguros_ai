services:
  db:
    image: pgvector/pgvector:pg16
    container_name: agente_db
    environment:
      POSTGRES_USER: agente
      POSTGRES_PASSWORD: agente_pw
      POSTGRES_DB: agente_ai
    ports:
      - "5433:5432"
    volumes:
      - agente_db_data:/var/lib/postgresql/data

  n8n:
    image: n8nio/n8n:latest
    container_name: agente_n8n
    depends_on:
      - db
    ports:
      - "5678:5678"
    environment:
      - TZ=Europe/Madrid
      - N8N_LISTEN_ADDRESS=0.0.0.0

      - N8N_ENCRYPTION_KEY=${N8N_ENCRYPTION_KEY}

      - WEBHOOK_URL=${WEBHOOK_URL}
      - N8N_EDITOR_BASE_URL=${N8N_EDITOR_BASE_URL}
      - N8N_HOST=${N8N_HOST}
      - N8N_PROTOCOL=${N8N_PROTOCOL}
      - N8N_PORT=${N8N_PORT}
      - N8N_URL=${N8N_URL}

      - N8N_BASIC_AUTH_ACTIVE=${N8N_BASIC_AUTH_ACTIVE}

    volumes:
      - n8n_data:/home/node/.n8n

  cloudflared:
    image: cloudflare/cloudflared:latest
    container_name: agente_cloudflared
    restart: unless-stopped
    depends_on:
      - n8n
    command: tunnel --no-autoupdate --config /etc/cloudflared/config.yml run --token ${CLOUDFLARE_TUNNEL_TOKEN}
    volumes:
      - ./cloudflared/config.yml:/etc/cloudflared/config.yml:ro

volumes:
  agente_db_data:
  n8n_data:
    external: true
    name: n8n_data